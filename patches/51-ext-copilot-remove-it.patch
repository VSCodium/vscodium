-export function parseEventLog(content: string): ICopilotEventLogEntry[] {
-	const entries: ICopilotEventLogEntry[] = [];
-	for (const line of content.split('\n')) {
-		const trimmed = line.trim();
-		if (trimmed.length === 0) {
-			continue;
-		}
-		entries.push(JSON.parse(trimmed));
-	}
-	return entries;
-}
