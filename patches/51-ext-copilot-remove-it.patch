-	for (let i = 0; i < entries.length; i++) {
-		const entry = entries[i];
-
-		if (entry.type === 'user.message') {
-			userMessageCount++;
-			if (userMessageCount > turnIndex) {
-				// We've entered the next turn — stop
-				return lastEventForTurn;
-			}
-		}
